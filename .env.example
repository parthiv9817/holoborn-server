# === Already have ===
OPENAI_API_KEY=sk-...
RUNPOD_API_KEY=...
RUNPOD_ENDPOINT_ID=pz2c4wvo2rcdw9
GPU_SERVER_URL=https://api.runpod.ai/v2/pz2c4wvo2rcdw9

# === Model swap toggle (no code change to A/B test) ===
GPT_IMAGE_MODEL=gpt-image-1.5  # flip to gpt-image-2 later

# === RunPod S3 — grab these from RunPod console ===
RUNPOD_S3_ACCESS_KEY=
RUNPOD_S3_SECRET_KEY=
RUNPOD_S3_ENDPOINT=          # e.g. https://s3api-eu-cz-1.runpod.io
RUNPOD_S3_BUCKET=            # network volume UUID, NOT the name "holoborn-weights"
RUNPOD_S3_REGION=            # same region as endpoint, e.g. eu-cz-1

# === Polling tunables (defaults are fine) ===
RUNPOD_POLL_INTERVAL_S=5.0
RUNPOD_POLL_TIMEOUT_S=600.0
RUNPOD_S3_KEEP_AFTER_DOWNLOAD=false

# === App config ===
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
